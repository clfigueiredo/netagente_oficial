# ══════════════════════════════════════════════════════════════
# NetAgent Platform — Environment Variables Template
# Copy this file as .env and fill in the values
# ══════════════════════════════════════════════════════════════

# ── Banco de Dados
POSTGRES_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
DATABASE_URL=postgresql://netagent:SAME_PASSWORD_AS_ABOVE@localhost:5432/netagent

# ── Redis
REDIS_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
REDIS_URL=redis://:SAME_PASSWORD_AS_ABOVE@localhost:6379

# ── Segurança
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# ── OpenAI
OPENAI_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# ── Evolution API (WhatsApp)
EVOLUTION_GLOBAL_KEY=GENERATE_WITH_openssl_rand_hex_32
EVOLUTION_BASE_URL=https://your-evolution-domain.com

# ── URLs
PUBLIC_URL=https://your-platform-domain.com
VITE_API_URL=https://your-platform-domain.com/api
VITE_WS_URL=https://your-platform-domain.com

# ── App
NODE_ENV=production
PORT=4000
AGENT_PORT=8000
LOG_LEVEL=info
INTERNAL_API_SECRET=GENERATE_WITH_openssl_rand_hex_32
