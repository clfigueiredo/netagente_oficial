# ══════════════════════════════════════════════════════════════
# NetAgent Platform — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────────────
.env
.env.local
.env.production.local
api/.env
agent/.env

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
agent/venv/
.venv/
*.egg-info/

# ── Build artifacts ───────────────────────────────────────────
frontend/dist/
frontend/dist-serve/

# ── Runtime Data (database, cache, backups) ───────────────────
data/postgres/
data/redis/
data/evolution/
data/wireguard/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── SSL / Certificates ───────────────────────────────────────
traefik/certs/acme.json

# ── Release / Build packages ─────────────────────────────────
netagent-release/
netagent-installer.tar.gz

# ── IDE & Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Gemini / AI Agent workspace ──────────────────────────────
.agent/
.claude/

# ── MCP __pycache__ ──────────────────────────────────────────
mcp-mikrotik/__pycache__/
mcp-linux/__pycache__/
mcp-postgres/__pycache__/

# ── Lock files (keep package-lock.json, pnpm-lock.yaml) ──────
# package-lock.json and pnpm-lock.yaml ARE tracked (intentional)
